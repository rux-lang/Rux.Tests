import Std::{ String, Print };
import Std::Math::{ Pi, E };

func Main() -> int {
    var str1 = String::From("First line");
    var str2 = String::From("Second line\n");
    var str = str1 + " - middle - " + str2;
    Print(str);
    Print("Pi: {}\n", 3.14159265358979323846f64);
    return 0;
}
