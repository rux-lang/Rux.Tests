import Std::Memory::{ Alloc, Free };
import Std::Platform::{ PrintPointer };

func Main() -> int {
    var ptr = Alloc(10000000);
    PrintPointer("Pointer: {}\n", ptr);
    Free(ptr);
    return 0;
}
