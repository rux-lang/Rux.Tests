import Std::Platform::PrintLine;

func Main() -> int {
    var a = 100;
    var b = 200;
    if a > b {
        PrintLine("a is greater than b");
    } else if a == b {
        PrintLine("a is equal to b");
    } else {
        PrintLine("b is greater than a");
    }
    return 0;
}
