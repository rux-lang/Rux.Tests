func Greet() {
    print("Hello, World!");
}

func Add(a: float32, b: float32) -> float32 {
    return a + b;
}

func Min(a: float32, b: float32) -> float32 {
    if (a < b) {
        return a;
    } else {
        return b;
    }
}

func Max<T>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

type Handler = func(x, y: int32);
